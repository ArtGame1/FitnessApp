<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ececec"
    tools:context=".activities.AccountActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- Фоновое изображение -->
                <ImageView
                    android:id="@+id/imageView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    android:scaleType="fitXY"
                    app:srcCompat="@drawable/top_background"/>

                <!-- Аватар -->
                <ImageView
                    android:id="@+id/imageView2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="@id/imageView"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@id/imageView"
                    app:layout_constraintTop_toBottomOf="@id/imageView"
                    app:srcCompat="@drawable/profile"/>

                <!-- Имя пользователя (загружается из Firebase) -->
                <TextView
                    android:id="@+id/textView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Имя пользователя"
                    android:layout_marginTop="16dp"
                    android:textSize="25sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="@id/imageView2"
                    app:layout_constraintStart_toStartOf="@id/imageView2"
                    app:layout_constraintTop_toBottomOf="@id/imageView2"/>

                <!-- Email пользователя (загружается из Firebase) -->
                <TextView
                    android:id="@+id/textView2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="email@example.com"
                    android:textSize="16sp"
                    android:textColor="#666"
                    app:layout_constraintEnd_toEndOf="@id/textView"
                    app:layout_constraintStart_toStartOf="@id/textView"
                    app:layout_constraintTop_toBottomOf="@id/textView"/>

                <!-- ===== НОВАЯ КНОПКА "РЕДАКТИРОВАТЬ ПРОФИЛЬ" ===== -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_edit_profile"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Редактировать профиль"
                    android:textSize="14sp"
                    android:textAllCaps="false"
                    android:layout_marginTop="12dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:background="@drawable/btn_background_edit"
                    android:textColor="#4CAF50"
                    app:layout_constraintEnd_toEndOf="@id/textView2"
                    app:layout_constraintStart_toStartOf="@id/textView2"
                    app:layout_constraintTop_toBottomOf="@id/textView2"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="20dp"
                    app:layout_constraintTop_toBottomOf="@+id/btn_edit_profile">

                    <!-- Мои отзывы -->
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/button"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:text="Мои отзывы"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        style="@android:style/Widget.Button"
                        android:textAlignment="viewStart"
                        android:layout_marginStart="32dp"
                        android:layout_marginEnd="32dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/btn_background_1"
                        android:drawablePadding="20dp"
                        android:paddingStart="20dp"
                        android:layout_marginBottom="10dp"
                        android:drawableStart="@drawable/ic_1"/>

                    <!-- Настройки учетной записи → ОТКРЫВАЕТ EditProfileActivity -->
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/button2"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:text="Настройки учетной записи"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        style="@android:style/Widget.Button"
                        android:textAlignment="viewStart"
                        android:layout_marginStart="32dp"
                        android:layout_marginEnd="32dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/btn_background_1"
                        android:drawablePadding="20dp"
                        android:paddingStart="20dp"
                        android:layout_marginBottom="10dp"
                        android:drawableStart="@drawable/ic_2"/>

                    <!-- Личные данные -->
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/button3"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:text="Личные данные"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        style="@android:style/Widget.Button"
                        android:textAlignment="viewStart"
                        android:layout_marginStart="32dp"
                        android:layout_marginEnd="32dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/btn_background_1"
                        android:drawablePadding="20dp"
                        android:paddingStart="20dp"
                        android:layout_marginBottom="10dp"
                        android:drawableStart="@drawable/ic_3"/>

                    <!-- Уведомление -->
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/button4"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:text="Уведомление"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        style="@android:style/Widget.Button"
                        android:textAlignment="viewStart"
                        android:layout_marginStart="32dp"
                        android:layout_marginEnd="32dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/btn_background_1"
                        android:drawablePadding="20dp"
                        android:paddingStart="20dp"
                        android:layout_marginBottom="10dp"
                        android:drawableStart="@drawable/ic_4"/>

                    <!-- Настройки отпечатков пальцев -->
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/button5"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:text="Настройки отпечатков пальцев"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        style="@android:style/Widget.Button"
                        android:textAlignment="viewStart"
                        android:layout_marginStart="32dp"
                        android:layout_marginEnd="32dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/btn_background_1"
                        android:drawablePadding="20dp"
                        android:paddingStart="20dp"
                        android:layout_marginBottom="10dp"
                        android:drawableStart="@drawable/ic_5"/>

                    <!-- Вернуться на главную страницу -->
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btn_back_to_main_page"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        style="@android:style/Widget.Button"
                        android:background="@drawable/red_button_background"
                        android:layout_marginEnd="32dp"
                        android:layout_marginStart="32dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="32dp"
                        android:textColor="#ffffff"
                        android:text="Вернуться на главную страницу"
                        android:textStyle="bold"
                        android:textSize="16sp"/>

                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>